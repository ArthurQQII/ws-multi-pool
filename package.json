{
  "name": "ws-multi-pool",
  "version": "0.0.2",
  "description": "High-performance multiplexed WebSocket connection pool for Node.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "publish:public": "pnpm publish --no-git-checks --access public"
  },
  "keywords": [
    "websocket",
    "pool",
    "multiplex",
    "reconnect",
    "typescript",
    "load-balancing",
    "round-robin",
    "connection-pool"
  ],
  "author": "Arthur Qi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArthurQQII/ws-multi-pool.git"
  },
  "bugs": {
    "url": "https://github.com/ArthurQQII/ws-multi-pool/issues"
  },
  "homepage": "https://github.com/ArthurQQII/ws-multi-pool#readme",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}